# Loaded in order: project root `.env` then `backend/.env` (backend wins on duplicate keys).
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/medibook_db
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_REFRESH_SECRET=your_refresh_secret_key_here_make_it_long_and_random
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Mailtrap (https://mailtrap.io → SMTP settings). Leave MAIL_USER empty to log emails to the console instead.
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=MediBook <no-reply@medibook.local>
